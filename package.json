    "dotenv": "^16.4.0",
    "jose": "^6.2.0",
    "next": "^16.1.6",
    "node-telegram-bot-api": "^0.66.0",
    "postcss": "^8.5.8",
    "prisma": "^6.19.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.9.3",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-telegram-bot-api": "^0.64.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.0"
